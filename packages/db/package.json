{
  "name": "@jahf-comm/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./customer-memory": {
      "types": "./src/customer-memory.ts",
      "import": "./src/customer-memory.ts"
    }
  },
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.json",
    "lint": "eslint src prisma --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio --schema prisma/schema.prisma",
    "customer-memory:backfill": "tsx scripts/backfill-customer-memory.ts",
    "test:customer-memory": "tsx --test tests/customer-memory.test.ts",
    "production:seed-admin": "tsx scripts/create-admin.ts"
  },
  "dependencies": {
    "@jahf-comm/shared": "workspace:*",
    "@prisma/adapter-pg": "latest",
    "@prisma/client": "latest",
    "dotenv": "latest",
    "pg": "latest",
    "tsx": "latest"
  },
  "devDependencies": {
    "@types/pg": "latest",
    "prisma": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
