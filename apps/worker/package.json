{
  "name": "@jahf-comm/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src scripts --max-warnings=0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "queue:test": "tsx scripts/queue-test.ts"
  },
  "dependencies": {
    "@jahf-comm/ai": "workspace:*",
    "@jahf-comm/db": "workspace:*",
    "@jahf-comm/shared": "workspace:*",
    "bullmq": "latest",
    "ioredis": "latest",
    "tsx": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "typescript": "latest"
  }
}
