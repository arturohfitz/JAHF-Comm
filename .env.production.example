# Copy this file to .env.production on the server.
# Never commit .env.production or real secrets to GitHub.

APP_URL="https://comms.jahfconnect.com"
NODE_ENV="production"

# Docker Compose Postgres service values.
POSTGRES_USER="jahf_comm"
POSTGRES_PASSWORD=""
POSTGRES_DB="jahf_comm"

# Internal service URLs for docker-compose.production.yml.
DATABASE_URL="postgresql://jahf_comm:REPLACE_WITH_PASSWORD@postgres:5432/jahf_comm?schema=public"
REDIS_URL="redis://redis:6379"

# Required production secrets. Use long random values.
SESSION_SECRET=""
WEBHOOK_SECRET=""

# Evolution API preparation. Keep fallback disabled in production.
EVOLUTION_ALLOW_DEMO_FALLBACK="false"
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""

# AI classification. Leave OPENAI_API_KEY empty to use mock mode until real AI is enabled.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.5"
AI_CLASSIFICATION_ENABLED="true"

# Local demo seed values. Do not use change-this-password in production.
DEMO_ADMIN_EMAIL=""
DEMO_ADMIN_PASSWORD=""

# First production owner. Used only by pnpm production:seed-admin.
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_TENANT_NAME="JAHF Comm"
ADMIN_TENANT_SLUG="jahf-comm"
